{% extends 'dnd/plantillas/plantillaTablas.html.twig' %}
{% import "macros/ordenarTablas.html.twig" as t %}

{% block tabla_titulo %}LISTA DE CAPÍTULOS{% endblock %}

{% block tabla_cabecera %}
            {{ t.ordenar('id', 'ID', sort, direction, '10%') }}
            {{ t.ordenar('titulo', 'NOMBRE', sort, direction, '25%') }}
            {{ t.ordenar('resumen', 'RESUMEN', sort, direction, 'auto') }}
{% endblock %}

{% block tabla_filas %}
            <td>{{ objeto.numero }}</td>
            <td>{{ objeto.titulo }}</td>
            <td>{{ objeto.resumen }}</td>
{% endblock %}

