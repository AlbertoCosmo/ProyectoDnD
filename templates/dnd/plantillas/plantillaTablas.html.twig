<div class="cajaTabla">
    <div class="utilesTabla">
        <div class="accionesIzquierdaTabla">
            {% block top_extra %}{% endblock %}
        </div>
        <div class="accionesDerechaTabla">
            {% block buscador_tabla %}
            <div class=" filtroTabla">
                <button id="btnAbrirFiltro" class="btnFiltro">🔍</button>
                <div id="controlesFiltro">
                    {# SELECT 1 / ELEGIR COLUMNA #}
                    <select id="filtroCampo">
                        <option value="">-- Buscar en todo --</option>
                        {% for a in atributos %}
                        <option value="{{ a.attr }}" {{ campo_actual==a.attr ? 'selected' : '' }}>
                            {{ a.etiqueta }}
                        </option>
                        {% endfor %}
                    </select>

                    {# SELECT 2 / INPUT O SELECT #}
                    <div id="valorFiltroContenedor">
                        {% if opciones_relacion is not empty %}
                        <select id="busquedaTabla">
                            <option value="">Cualquiera...</option>
                            {% for opc in opciones_relacion %}
                            <option value="{{ opc.id }}" {{ busqueda==opc.id ? 'selected' : '' }}>
                                {{ opc.nombre|default(opc.id) }}
                            </option>
                            {% endfor %}
                        </select>
                        {% else %}
                        <input type="text" id="busquedaTabla" placeholder="Escribe para buscar..."
                            value="{{ busqueda }}" autocomplete="off">
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endblock %}
            {% block botones_vistas_tabla %}{% endblock %}
        </div>
    </div>
    <div id="vistaTabla">
        <table>
            <caption class="tablaTitulo">
                {% block tabla_titulo %}Título Placeholder{% endblock %}
            </caption>
            <thead>
                <tr>
                    {% for a in atributos %}
                    <th>{{ a.etiqueta }}</th>
                    {% endfor %}
                    {% block cabecera_extra %}{% endblock %}
                    <th style="width: 5%;">EDITAR</th>
                </tr>
            </thead>
            <tbody>
                {% for objeto in datos %}
                <tr>
                    {% for a in atributos %}
                    <td data-tipo="{{ a.tipo }}" data-campo="{{ a.attr }}">
                        {% set valor = attribute(objeto, a.attr) %}
                        {% if a.tipo == 'relacion' %} {# SI ES OBJETO: TAL #}
                        {{ valor.nombre|default(valor.id)|default('Sin asignar') }}
                        {% elseif a.tipo == 'bool' %} {# SI ES BOOLEANO: CUAL #}
                        {{ valor ? 'Si' : 'No' }}
                        {% else %} {# SI NO, SEGUIMOS CON LO DE SIEMPRE #}
                        {{ valor|default('---') }}
                        {% endif %}
                    </td>
                    {% endfor %}
                    <td>
                        <a href="#" class="btnMod" data-id="{{ objeto.id }}" data-entidad="{{ nombre_seccion }}">
                            ✎
                        </a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <div id="vistaMosaico" style="display: none;">
        {% block vista_mosaico %}{% endblock %}
    </div>
    {% block bot_extra %}
    <div class="paginacion" id="controlesPaginacion">
        {% if total_paginas > 1 %}
        <button class="btnPag" data-pagina="{{ pagina_actual - 1 }}" {{ pagina_actual==1 ? 'disabled' : '' }}>
            &lt;
        </button>
        <span class="infoPag">
            Página <strong>{{ pagina_actual }}</strong> de {{ total_paginas }}
        </span>
        <button class="btnPag" data-pagina="{{ pagina_actual + 1 }}" {{ pagina_actual==total_paginas ? 'disabled' : ''
            }}>
            &gt;
        </button>
        {% endif %}
    </div>
    {% endblock %}
</div>