{% extends 'base.html.twig' %}

{% block title %}Inicio de sesión{% endblock %}

{% block body %}
    <div class="contenidoNuevoNpc" style="display: block; position: relative;">
        <h1 class="tituloNuevoNpc">Inicio de sesión</h1>

        <form action="{{ path('app_login') }}" method="POST">
            
            <div style="margin-bottom: 20px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Nombre de Usuario:</label>
                <input type="text" name="_username" class="listarSelect" style="width: 99%;" required>
            </div>

            <div style="margin-bottom: 20px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Contraseña:</label>
                <input type="password" name="_password" class="listarSelect" style="width: 99%;" required>
            </div>

            <div class="formularioNpcAcciones">
                <button type="submit" class="btnCrearNpc2">Iniciar Sesión</button>
                <a href="{{ path('paginaBase') }}" class="btnCancelar">Cancelar</a>
            </div>
        </form>
    </div>
{% endblock %}
